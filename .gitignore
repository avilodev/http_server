# Build output
bin/
obj/

# SSL certificates and private keys — never commit
etc/ssl/

# Runtime data — track directories via .gitkeep, ignore their contents
var/log/*
!var/log/.gitkeep
var/db/*
!var/db/.gitkeep

# Backup artifacts
backups/legacy/server

# IDE / editor
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
